# EJERCICIO 2, COMPARADOR DE NÚMEROS

print("Dame 2 números: ")
numero = int(input()) 
numero1 = int(input())
if numero < numero1 :
    print(f"El número {numero} es menor que {numero1}")
if numero == numero1 :
    print(f"Estos números son iguales")
if numero > numero1 :
    print(f"El número {numero} es mayor que {numero1}") 
